{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(open http://localhost:*)",
      "Bash(python3 -m http.server 8000)",
      "Bash(npm run layout)",
      "Bash(npm run validate)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/secret.*)",
      "Read(**/secrets.*)",
      "Read(**/credentials)",
      "Read(**/credentials.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.crt)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/id_ecdsa*)",
      "Read(**/id_dsa*)",
      "Read(**/.npmrc)",
      "Read(**/.netrc)",
      "Read(**/.pypirc)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/.gnupg/**)",
      "Read(**/.gcp/**)",
      "Read(**/service-account*.json)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/secrets/**)",
      "Edit(**/secret.*)",
      "Edit(**/credentials)",
      "Edit(**/credentials.*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/*.crt)",
      "Edit(**/*.p12)",
      "Edit(**/*.pfx)",
      "Edit(**/id_rsa*)",
      "Edit(**/id_ed25519*)",
      "Edit(**/id_ecdsa*)",
      "Edit(**/id_dsa*)",
      "Edit(**/.npmrc)",
      "Edit(**/.netrc)",
      "Edit(**/.pypirc)",
      "Edit(**/.aws/**)",
      "Edit(**/.ssh/**)",
      "Edit(**/.gnupg/**)",
      "Edit(**/.gcp/**)",
      "Edit(**/service-account*.json)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/secrets/**)",
      "Write(**/secret.*)",
      "Write(**/credentials)",
      "Write(**/credentials.*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/*.crt)",
      "Write(**/*.p12)",
      "Write(**/*.pfx)",
      "Write(**/id_rsa*)",
      "Write(**/id_ed25519*)",
      "Write(**/id_ecdsa*)",
      "Write(**/id_dsa*)",
      "Write(**/.npmrc)",
      "Write(**/.netrc)",
      "Write(**/.pypirc)",
      "Write(**/.aws/**)",
      "Write(**/.ssh/**)",
      "Write(**/.gnupg/**)",
      "Write(**/.gcp/**)",
      "Write(**/service-account*.json)",

      "Bash(git push:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(scp:*)",
      "Bash(rsync:*)"
    ]
  }
}
