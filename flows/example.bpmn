<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Example" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Example_Process" isExecutable="false">
    <bpmn:startEvent id="Start_Event" name="Start">
      <bpmn:outgoing>Flow_Start_To_Task</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Do_Work" name="Aufgabe erledigen">
      <bpmn:incoming>Flow_Start_To_Task</bpmn:incoming>
      <bpmn:outgoing>Flow_Task_To_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Event" name="Done">
      <bpmn:incoming>Flow_Task_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_Task" sourceRef="Start_Event" targetRef="Do_Work" />
    <bpmn:sequenceFlow id="Flow_Task_To_End" sourceRef="Do_Work" targetRef="End_Event" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Example_Process">
    <bpmndi:BPMNPlane id="BPMNPlane_Example_Process" bpmnElement="Example_Process">
      <bpmndi:BPMNShape id="Start_Event_di" bpmnElement="Start_Event">
        <dc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Do_Work_di" bpmnElement="Do_Work">
        <dc:Bounds x="175" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Event_di" bpmnElement="End_Event">
        <dc:Bounds x="357" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_To_Task_di" bpmnElement="Flow_Start_To_Task">
        <di:waypoint x="93" y="70" />
        <di:waypoint x="175" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Task_To_End_di" bpmnElement="Flow_Task_To_End">
        <di:waypoint x="275" y="70" />
        <di:waypoint x="357" y="70" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
