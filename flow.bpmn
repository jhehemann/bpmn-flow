<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_Invoice_Approval" isExecutable="false">
    <bpmn:startEvent id="Invoice_Received" name="Rechnung eingegangen">
      <bpmn:outgoing>Flow_Start_Capture</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Capture_Task" name="Rechnung erfassen">
      <bpmn:incoming>Flow_Start_Capture</bpmn:incoming>
      <bpmn:outgoing>Flow_Capture_Split</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="Split_Gateway" name="parallel prüfen">
      <bpmn:incoming>Flow_Capture_Split</bpmn:incoming>
      <bpmn:outgoing>Flow_Split_Sach</bpmn:outgoing>
      <bpmn:outgoing>Flow_Split_Formal</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="Sachpruefung_Task" name="Sachliche Prüfung">
      <bpmn:incoming>Flow_Split_Sach</bpmn:incoming>
      <bpmn:outgoing>Flow_Sach_Join</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Formalpruefung_Task" name="Formale Prüfung">
      <bpmn:incoming>Flow_Split_Formal</bpmn:incoming>
      <bpmn:outgoing>Flow_Formal_Join</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="Join_Gateway" name="zusammenführen">
      <bpmn:incoming>Flow_Sach_Join</bpmn:incoming>
      <bpmn:incoming>Flow_Formal_Join</bpmn:incoming>
      <bpmn:outgoing>Flow_Join_Approval</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:exclusiveGateway id="Approval_Gateway" name="Freigabe?">
      <bpmn:incoming>Flow_Join_Approval</bpmn:incoming>
      <bpmn:outgoing>Flow_Approve_Pay</bpmn:outgoing>
      <bpmn:outgoing>Flow_Approve_Reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Pay_Task" name="Zahlung anweisen">
      <bpmn:incoming>Flow_Approve_Pay</bpmn:incoming>
      <bpmn:outgoing>Flow_Pay_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Paid_End" name="Bezahlt">
      <bpmn:incoming>Flow_Pay_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Reject_Task" name="Rechnung ablehnen">
      <bpmn:incoming>Flow_Approve_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_Reject_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="Rejected_End" name="Abgelehnt">
      <bpmn:incoming>Flow_Reject_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Capture" sourceRef="Invoice_Received" targetRef="Capture_Task" />
    <bpmn:sequenceFlow id="Flow_Capture_Split" sourceRef="Capture_Task" targetRef="Split_Gateway" />
    <bpmn:sequenceFlow id="Flow_Split_Sach" sourceRef="Split_Gateway" targetRef="Sachpruefung_Task" />
    <bpmn:sequenceFlow id="Flow_Split_Formal" sourceRef="Split_Gateway" targetRef="Formalpruefung_Task" />
    <bpmn:sequenceFlow id="Flow_Sach_Join" sourceRef="Sachpruefung_Task" targetRef="Join_Gateway" />
    <bpmn:sequenceFlow id="Flow_Formal_Join" sourceRef="Formalpruefung_Task" targetRef="Join_Gateway" />
    <bpmn:sequenceFlow id="Flow_Join_Approval" sourceRef="Join_Gateway" targetRef="Approval_Gateway" />
    <bpmn:sequenceFlow id="Flow_Approve_Pay" name="ja" sourceRef="Approval_Gateway" targetRef="Pay_Task" />
    <bpmn:sequenceFlow id="Flow_Pay_End" sourceRef="Pay_Task" targetRef="Paid_End" />
    <bpmn:sequenceFlow id="Flow_Approve_Reject" name="nein" sourceRef="Approval_Gateway" targetRef="Reject_Task" />
    <bpmn:sequenceFlow id="Flow_Reject_End" sourceRef="Reject_Task" targetRef="Rejected_End" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_Invoice_Approval">
      <bpmndi:BPMNShape id="Invoice_Received_di" bpmnElement="Invoice_Received">
        <dc:Bounds x="172" y="102" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Capture_Task_di" bpmnElement="Capture_Task">
        <dc:Bounds x="260" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Split_Gateway_di" bpmnElement="Split_Gateway">
        <dc:Bounds x="420" y="95" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="480" y="113" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sachpruefung_Task_di" bpmnElement="Sachpruefung_Task">
        <dc:Bounds x="530" y="20" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Join_Gateway_di" bpmnElement="Join_Gateway">
        <dc:Bounds x="690" y="95" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="594.5" y="113" width="85" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Approval_Gateway_di" bpmnElement="Approval_Gateway" isMarkerVisible="true">
        <dc:Bounds x="800" y="95" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="800" y="71" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Pay_Task_di" bpmnElement="Pay_Task">
        <dc:Bounds x="900" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Paid_End_di" bpmnElement="Paid_End">
        <dc:Bounds x="1052" y="102" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Reject_Task_di" bpmnElement="Reject_Task">
        <dc:Bounds x="775" y="310" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Rejected_End_di" bpmnElement="Rejected_End">
        <dc:Bounds x="1002" y="312" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="995" y="348" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Formalpruefung_Task_di" bpmnElement="Formalpruefung_Task">
        <dc:Bounds x="530" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_Capture_di" bpmnElement="Flow_Start_Capture">
        <di:waypoint x="208" y="120" />
        <di:waypoint x="260" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Capture_Split_di" bpmnElement="Flow_Capture_Split">
        <di:waypoint x="360" y="120" />
        <di:waypoint x="420" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Split_Sach_di" bpmnElement="Flow_Split_Sach">
        <di:waypoint x="445" y="95" />
        <di:waypoint x="445" y="60" />
        <di:waypoint x="530" y="60" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Split_Formal_di" bpmnElement="Flow_Split_Formal">
        <di:waypoint x="445" y="145" />
        <di:waypoint x="445" y="240" />
        <di:waypoint x="530" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Sach_Join_di" bpmnElement="Flow_Sach_Join">
        <di:waypoint x="630" y="60" />
        <di:waypoint x="715" y="60" />
        <di:waypoint x="715" y="95" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Formal_Join_di" bpmnElement="Flow_Formal_Join">
        <di:waypoint x="630" y="240" />
        <di:waypoint x="715" y="240" />
        <di:waypoint x="715" y="145" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Join_Approval_di" bpmnElement="Flow_Join_Approval">
        <di:waypoint x="740" y="120" />
        <di:waypoint x="800" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Approve_Pay_di" bpmnElement="Flow_Approve_Pay">
        <di:waypoint x="850" y="120" />
        <di:waypoint x="900" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Pay_End_di" bpmnElement="Flow_Pay_End">
        <di:waypoint x="1000" y="120" />
        <di:waypoint x="1052" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Approve_Reject_di" bpmnElement="Flow_Approve_Reject">
        <di:waypoint x="825" y="145" />
        <di:waypoint x="825" y="310" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="830" y="217" width="21" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Reject_End_di" bpmnElement="Flow_Reject_End">
        <di:waypoint x="875" y="350" />
        <di:waypoint x="901" y="350" />
        <di:waypoint x="901" y="330" />
        <di:waypoint x="1002" y="330" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
